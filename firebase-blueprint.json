{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier for the user" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" }
      },
      "required": ["uid", "email"]
    },
    "TaxAnalysis": {
      "title": "Tax Analysis Result",
      "description": "Stores the result of a tax document analysis",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Owner of the analysis" },
        "financialYear": { "type": "string", "description": "FY for the analysis" },
        "summary": { "type": "object", "description": "High-level tax summary" },
        "detailedBreakdown": { "type": "string", "description": "Markdown report" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Analysis timestamp" }
      },
      "required": ["userId", "financialYear", "summary", "detailedBreakdown"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents"
    },
    "/users/{userId}/analyses/{analysisId}": {
      "schema": "TaxAnalysis",
      "description": "User's tax analysis history"
    }
  }
}
